# Copy to .env and adjust. docker-compose reads these via the app service env.
DB_DSN=postgresql://logocean:logocean@localhost:5432/logocean
# Minimum retention. The app never auto-deletes below this; purge is manual unless AUTO_PURGE=true.
RETENTION_YEARS=3
# Rows per search page.
PAGE_SIZE=100
# Reject uploads larger than this (MB).
MAX_UPLOAD_MB=512
# If true, a daily purge drops partitions older than RETENTION_YEARS. Default false (keep everything).
AUTO_PURGE=false

# ── Detection & alerting (Phase 2) ─────────────────────────────────────────
# Evaluate rules in rules/ and raise alerts. Correlation rules run on a timer.
DETECTION_ENABLED=true
CORRELATION_INTERVAL=60

# ── Notifications (Phase 3) ────────────────────────────────────────────────
# Send newly-raised alerts at or above NOTIFY_MIN_LEVEL to the channels below.
NOTIFY_ENABLED=false
NOTIFY_MIN_LEVEL=high            # informational | low | medium | high | critical
# Webhook channel: a Slack/Teams/Discord incoming webhook or any HTTP endpoint.
WEBHOOK_URL=
WEBHOOK_STYLE=slack              # slack (text payload) | json (full alert)
# Email channel (SMTP). Needs SMTP_HOST + SMTP_FROM + SMTP_TO to activate.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=                         # comma-separated recipients
SMTP_TLS=true

# ── Agentless response (Phase 3) ───────────────────────────────────────────
# Run playbooks in playbooks/ on matching alerts. Webhook actions POST the intent
# (e.g. block_ip + target) to your automation/SOAR endpoint; `log` actions don't.
RESPONSE_ENABLED=false
RESPONSE_WEBHOOK_URL=

# ── Live ingestion (Phase 1) ───────────────────────────────────────────────
# Async ingest queue: live sources buffer here; writer workers batch-insert.
INGEST_QUEUE_MAX=10000
INGEST_WORKERS=2
INGEST_FLUSH_MAX=2000
INGEST_FLUSH_MS=1000
# Syslog receiver. Off by default. Port 5514 so the non-root container needn't
# bind privileged 514. Set a port to 0 to disable that transport.
SYSLOG_ENABLED=false
SYSLOG_HOST=0.0.0.0
SYSLOG_UDP_PORT=5514
SYSLOG_TCP_PORT=5514
# Fixed parser for all messages, or "auto" to detect per message (falls back to
# generic syslog). A fixed format is cheaper at high volume.
SYSLOG_FORMAT=auto
# TLS for syslog-over-TCP (optional): point both at PEM files to enable.
SYSLOG_TLS_CERT=
SYSLOG_TLS_KEY=
