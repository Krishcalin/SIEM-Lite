# Copy to .env and adjust. docker-compose reads these via the app service env.
DB_DSN=postgresql://logocean:logocean@localhost:5432/logocean
# Minimum retention. The app never auto-deletes below this; purge is manual unless AUTO_PURGE=true.
RETENTION_YEARS=3
# Rows per search page.
PAGE_SIZE=100
# Reject uploads larger than this (MB).
MAX_UPLOAD_MB=512
# If true, a daily purge drops partitions older than RETENTION_YEARS. Default false (keep everything).
AUTO_PURGE=false

# ── Detection & alerting (Phase 2) ─────────────────────────────────────────
# Evaluate rules in rules/ and raise alerts. Correlation rules run on a timer.
DETECTION_ENABLED=true
CORRELATION_INTERVAL=60

# ── Notifications (Phase 3) ────────────────────────────────────────────────
# Send newly-raised alerts at or above NOTIFY_MIN_LEVEL to the channels below.
NOTIFY_ENABLED=false
NOTIFY_MIN_LEVEL=high            # informational | low | medium | high | critical
# Webhook channel: a Slack/Teams/Discord incoming webhook or any HTTP endpoint.
WEBHOOK_URL=
WEBHOOK_STYLE=slack              # slack (text payload) | json (full alert)
# Email channel (SMTP). Needs SMTP_HOST + SMTP_FROM + SMTP_TO to activate.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=                         # comma-separated recipients
SMTP_TLS=true

# ── Agentless response (Phase 3) ───────────────────────────────────────────
# Run playbooks in playbooks/ on matching alerts. Webhook actions POST the intent
# (e.g. block_ip + target) to your automation/SOAR endpoint; `log` actions don't.
RESPONSE_ENABLED=false
RESPONSE_WEBHOOK_URL=

# ── Agentless collectors (Phase 4) ─────────────────────────────────────────
# Scheduled pull of vendor logs into the ingest pipeline. A collector activates
# only when its credentials are set. COLLECTOR_INTERVAL is the poll period (s);
# COLLECTOR_LOOKBACK_HOURS is how far back the first run reaches.
COLLECTORS_ENABLED=false
COLLECTOR_INTERVAL=300
COLLECTOR_LOOKBACK_HOURS=24
OKTA_DOMAIN=                     # https://acme.okta.com
OKTA_TOKEN=
GITHUB_ORG=
GITHUB_TOKEN=
GITLAB_URL=                      # https://gitlab.com
GITLAB_TOKEN=
# AWS CloudTrail — SigV4-signed LookupEvents. Activates with region + keys.
AWS_REGION=                      # e.g. us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=               # optional, for STS temporary credentials
# Microsoft Entra ID / 365 — one Azure app registration (OAuth2 client creds).
# Entra sign-in logs activate with tenant+client+secret. The Microsoft 365
# unified audit log also needs M365_ENABLED=true (extra API permission + a
# started Office 365 Management Activity subscription).
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
M365_ENABLED=false
M365_CONTENT_TYPE=Audit.General  # Audit.AzureActiveDirectory|Exchange|SharePoint|General

# ── Threat-intelligence enrichment ─────────────────────────────────────────
# Match ingested events against IOC feeds (IPs/CIDRs/domains/hashes/URLs); a hit
# raises a "Threat Intelligence Match" alert. THREATINTEL_FEEDS is a comma/space
# separated list of local file paths or http(s) URLs (one-indicator-per-line,
# CSV, or JSON). Manual indicators added in the Admin UI also apply.
THREATINTEL_ENABLED=false
THREATINTEL_FEEDS=                 # e.g. /feeds/blocklist.txt,https://example/iocs.json
THREATINTEL_REFRESH_MINUTES=60
THREATINTEL_DEFAULT_SEVERITY=high

# ── UEBA / entity risk ──────────────────────────────────────────────────────
# Maintain per-entity (user/host/ip) baselines at ingest and score risk from
# attributed alerts (severity-weighted, decayed). The /risk page surfaces it.
# On by default (cheap upserts); RISK_HALF_LIFE_DAYS tunes how fast risk decays.
UEBA_ENABLED=true
RISK_HALF_LIFE_DAYS=7
RISK_WINDOW_DAYS=30

# ── Kill-chain reconstruction ───────────────────────────────────────────────
# Stitch related alerts (shared user/host/ip + time proximity) that span
# multiple ATT&CK tactics into attack stories on the /killchain page. Auto-create
# turns high-severity stories into cases on a schedule (opt-in).
KILLCHAIN_ENABLED=true
KILLCHAIN_WINDOW_HOURS=24
KILLCHAIN_MAX_GAP_MINUTES=60
KILLCHAIN_MIN_TACTICS=2
KILLCHAIN_AUTOCREATE=false
KILLCHAIN_INTERVAL=300
KILLCHAIN_MIN_SEVERITY=high

# ── Authentication & RBAC (Phase 5) ────────────────────────────────────────
# Built-in login + roles. Off by default (front with SSO/proxy instead). When
# true, an admin is bootstrapped on first run from ADMIN_USER/ADMIN_PASSWORD;
# if ADMIN_PASSWORD is blank a random one is generated and written to the logs.
AUTH_ENABLED=false
ADMIN_USER=admin
ADMIN_PASSWORD=
SESSION_TTL_HOURS=12
SESSION_COOKIE_SECURE=false       # set true when served over HTTPS

# ── Live ingestion (Phase 1) ───────────────────────────────────────────────
# Async ingest queue: live sources buffer here; writer workers batch-insert.
INGEST_QUEUE_MAX=10000
INGEST_WORKERS=2
INGEST_FLUSH_MAX=2000
INGEST_FLUSH_MS=1000
# Syslog receiver. Off by default. Port 5514 so the non-root container needn't
# bind privileged 514. Set a port to 0 to disable that transport.
SYSLOG_ENABLED=false
SYSLOG_HOST=0.0.0.0
SYSLOG_UDP_PORT=5514
SYSLOG_TCP_PORT=5514
# Fixed parser for all messages, or "auto" to detect per message (falls back to
# generic syslog). A fixed format is cheaper at high volume.
SYSLOG_FORMAT=auto
# TLS for syslog-over-TCP (optional): point both at PEM files to enable.
SYSLOG_TLS_CERT=
SYSLOG_TLS_KEY=
